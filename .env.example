# ============================================================
# Splitkar! — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# These two are SAFE to embed in the client bundle (EXPO_PUBLIC_*).
# They are readable by anyone who has the APK/IPA — that is expected.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_ANON_KEY_HERE

# These are SERVER-ONLY / CI secrets. NEVER prefix with EXPO_PUBLIC_.
# service_role bypasses all RLS — treat like a DB root password.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_SERVICE_ROLE_KEY_HERE
# Direct Postgres connection password (Supabase dashboard → Settings → Database)
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD_HERE
# Personal Access Token for Supabase CLI (supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=sbp_YOUR_PERSONAL_ACCESS_TOKEN_HERE

# ── EAS / Expo ──────────────────────────────────────────────
# Find in Expo dashboard → Project → Settings
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# ── Sentry ──────────────────────────────────────────────────
# SAFE to embed — it's a public DSN, not a secret.
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXXX.ingest.sentry.io/XXXXXXX

# ── PostHog ─────────────────────────────────────────────────
# SAFE to embed — it's a project API key, not a secret.
EXPO_PUBLIC_POSTHOG_API_KEY=phc_YOUR_POSTHOG_KEY
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
